# Live backend on Render (required for Google OAuth + shared MongoDB)
VITE_API_URL=https://gadkille-backend-clean.onrender.com/api

# Optional: override Vite dev proxy target (defaults to Render)
# VITE_API_PROXY_TARGET=https://gadkille-backend-clean.onrender.com

# Local-only: use Vite proxy to localhost backend
# VITE_API_URL=/api
# VITE_API_PROXY_TARGET=http://localhost:5000

VITE_GOOGLE_MAPS_API_KEY=your_key_here