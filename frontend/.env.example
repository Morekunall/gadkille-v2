# Local dev: Vite proxies /api to backend on port 5000 (see vite.config.js)
# VITE_API_URL=/api

# Production build (Render static site)
VITE_API_URL=https://api.gadkille.co.in/api
VITE_SITE_URL=https://gadkille.co.in
# Optional: override OAuth API host if different from VITE_API_URL
# VITE_OAUTH_API_ORIGIN=https://api.gadkille.co.in
