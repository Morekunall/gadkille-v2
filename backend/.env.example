PORT=5000
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=gadkille
JWT_SECRET=change_this_to_a_long_random_string
# Also signs Google OAuth "state" (must not change between /google and /callback).
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Comma-separated extra origins (ngrok URL, LAN IP frontend, etc.)
# CORS_ORIGINS=https://abc123.ngrok-free.app,http://192.168.1.5:5173

# Admin bootstrap (optional)
ADMIN_EMAIL=admin@gadkille.local
ADMIN_PASSWORD=change_me_in_production
ADMIN_NAME=GadKille Admin

# Google OAuth (optional)
# Create credentials at https://console.developers.google.com/
# and set the redirect URI to your backend's callback endpoint, for example:
# https://gadkille-backend-clean.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://gadkille-backend-clean.onrender.com/api/auth/google/callback

# SMTP (required in production for real emails)
# Must be a hostname like smtp.gmail.com — NOT your email address
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="GadKille" <noreply@gadkille.com>
