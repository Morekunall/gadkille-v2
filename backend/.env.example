PORT=5000
# MongoDB Atlas (required on Render — localhost will NOT work)
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/gadkille?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=gadkille
JWT_SECRET=change_this_to_a_long_random_string
# Also signs Google OAuth "state" (must not change between /google and /callback).
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Comma-separated extra origins (ngrok URL, LAN IP frontend, etc.)
# CORS_ORIGINS=https://abc123.ngrok-free.app,http://192.168.1.5:5173

# Admin bootstrap (optional)
ADMIN_EMAIL=admin@gadkille.local
ADMIN_PASSWORD=change_me_in_production
ADMIN_NAME=GadKille Admin
# Set to true once on Render to apply ADMIN_PASSWORD to an existing admin, then remove
# ADMIN_SYNC_PASSWORD=true

# Google OAuth (optional)
# Create credentials at https://console.developers.google.com/
# and set the redirect URI to your backend's callback endpoint, for example:
# https://gadkille-backend-clean.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://gadkille-backend-clean.onrender.com/api/auth/google/callback

# Email — Resend (required on Render; Gmail SMTP port 587 is blocked there)
# 1. https://resend.com → sign up → API Keys → create key
# 2. Set RESEND_API_KEY on Render → redeploy
# 3. Optional: verify your domain → set RESEND_FROM to your domain
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Gadkille <onboarding@resend.dev>

# LOCAL DEV ONLY — Gmail app password (do not rely on this on Render)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password
# EMAIL_FROM="GadKille" <your-email@gmail.com>
# SMTP_ALLOW_ON_RENDER=true   # only if you upgrade Render and SMTP works
